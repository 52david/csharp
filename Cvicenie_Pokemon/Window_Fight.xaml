<Window x:Class="Cvicenie_Pokemon.Window_Fight"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Cvicenie_Pokemon"
        mc:Ignorable="d"
        Title="Window_Fight" Height="450" Width="800">
    <Grid>
        <Image Margin="-64,29,414,179" Source="/Images/Pikachu.png" Stretch="Fill" RenderTransformOrigin="0.5,0.5" Visibility="Collapsed">
            <Image.RenderTransform>
                <TransformGroup>
                    <ScaleTransform/>
                    <SkewTransform/>
                    <RotateTransform Angle="0.225"/>
                    <TranslateTransform/>
                </TransformGroup>
            </Image.RenderTransform>
        </Image>
        <Image Margin="498,31,23,149" Source="/Images/Charizard.png" Stretch="Fill" Visibility="Collapsed"/>
        <Image Margin="529,0,0,148" Source="/Images/Charizard.png" Stretch="Fill"/>
        <Image Margin="-106,-2,376,169" Source="/Images/Pikachu.png" Stretch="Fill" RenderTransformOrigin="0.5,0.5">
            <Image.RenderTransform>
                <TransformGroup>
                    <ScaleTransform/>
                    <SkewTransform/>
                    <RotateTransform Angle="-0.052"/>
                    <TranslateTransform/>
                </TransformGroup>
            </Image.RenderTransform>
        </Image>
        <ProgressBar Name="ProgressBar_Hero" HorizontalAlignment="Left" Height="44" Margin="10,296,0,0" VerticalAlignment="Top" Width="310"/>
        <ProgressBar Name="ProgressBar_Enemy"  HorizontalAlignment="Left" Height="44" Margin="468,296,0,0" VerticalAlignment="Top" Width="310"/>
        <Button Name="LightAttack" Content="Light Attack" HorizontalAlignment="Left" Margin="10,345,0,0" VerticalAlignment="Top" Height="52" Width="90" Click="LightAttack_Click" Background="#FF4FD42F"/>
        <Button x:Name="MediumAttack" Content="Medium Attack" HorizontalAlignment="Left" Margin="105,345,0,0" VerticalAlignment="Top" Height="52" Width="113" Click="MediumAttack_Click" Background="#FFD8EB0A" />
        <Button x:Name="HardAttack_Copy1" Content="Hard Attack" HorizontalAlignment="Left" Margin="223,345,0,0" VerticalAlignment="Top" Height="52" Width="97" Click="HardAttack_Copy1_Click" Foreground="Black" Background="#FFF71414"/>
        <Label Name="Label_GameStatus"  Content="Label" HorizontalAlignment="Center" Margin="0,10,0,0" VerticalAlignment="Top" Height="72" Width="140" FontSize="36"/>
        <ProgressBar Name="ProgressBar_Energy"  HorizontalAlignment="Left" Height="22" Margin="10,402,0,0" VerticalAlignment="Top" Width="310" Foreground="#FFFFE600"/>
    </Grid>
</Window>
